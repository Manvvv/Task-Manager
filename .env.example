# ============================================================
#  TASKR — Task Manager  |  .env
#  Environment Variables — copy this to .env and fill in values
# ============================================================

# MongoDB connection URI
# Local:  mongodb://localhost:27017/taskr
# Atlas:  mongodb+srv://<username>:<password>@cluster.mongodb.net/taskr
MONGO_URI=mongodb://localhost:27017/taskr

# Server port
PORT=3000

# Node environment
NODE_ENV=development
